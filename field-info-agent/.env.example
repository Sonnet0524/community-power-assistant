# =============================================================================
# Field Info Agent - 环境变量配置模板
# =============================================================================
# 使用说明：
# 1. 复制此文件为 .env: cp .env.example .env
# 2. 修改 .env 文件中的值为实际配置
# 3. 确保 .env 文件已添加到 .gitignore
#
# 安全提示：
# - 不要将真实的 .env 文件提交到 Git
# - 生产环境使用强密码
# - 定期更换密码
# =============================================================================

# =============================================================================
# PostgreSQL 数据库配置
# =============================================================================

# 数据库用户名
POSTGRES_USER=field_user

# 数据库密码（生产环境请使用强密码）
POSTGRES_PASSWORD=field_pass

# 数据库名称
POSTGRES_DB=field_agent

# 数据库端口（主机映射）
POSTGRES_PORT=5432

# =============================================================================
# MinIO 对象存储配置
# =============================================================================

# MinIO 管理员账号
MINIO_ROOT_USER=minioadmin

# MinIO 管理员密码（生产环境请使用强密码）
MINIO_ROOT_PASSWORD=minioadmin123

# 默认 Bucket 名称
MINIO_BUCKET=field-documents

# MinIO API 端口（主机映射）
MINIO_PORT=9000

# MinIO 控制台端口（主机映射）
MINIO_CONSOLE_PORT=9001

# =============================================================================
# Redis 缓存配置
# =============================================================================

# Redis 密码（生产环境请使用强密码）
REDIS_PASSWORD=redispass

# Redis 端口（主机映射）
REDIS_PORT=6379

# =============================================================================
# Field Info Agent 应用配置（可选）
# =============================================================================

# 应用环境: development | testing | production
APP_ENV=development

# 应用端口
APP_PORT=8080

# 日志级别: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# =============================================================================
# KIMI API 配置（需要单独申请）
# =============================================================================

# KIMI API Key（从环境变量或密钥管理服务获取）
# KIMI_API_KEY=your_api_key_here

# KIMI API 基础 URL
# KIMI_BASE_URL=https://api.moonshot.cn/v1

# =============================================================================
# 企业微信配置（由 Integration Team 配置）
# =============================================================================

# 企业微信 CorpID
# WECOM_CORP_ID=your_corp_id

# 企业微信 AgentId
# WECOM_AGENT_ID=your_agent_id

# 企业微信 Secret
# WECOM_SECRET=your_secret

# 企业微信 Token
# WECOM_TOKEN=your_token

# 企业微信 EncodingAESKey
# WECOM_ENCODING_AES_KEY=your_encoding_aes_key
# KIMI API Configuration
KIMI_API_KEY=your_kimi_api_key_here
KIMI_BASE_URL=https://api.kimi.com/coding/
KIMI_MODEL=kimi-k2-5
