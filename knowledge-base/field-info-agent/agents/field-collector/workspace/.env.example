# ============================================================
# Field Info Collector - 环境变量配置模板
# 现场信息收集智能体 - 环境配置
# 
# 使用方法：
# 1. 复制此文件为 .env
# 2. 填写所有敏感信息
# 3. 确保 .env 在 .gitignore 中
# ============================================================

# ==========================================================
# 1. 企业微信配置
# ==========================================================
WECOM_CORP_ID=your_corp_id_here
WECOM_AGENT_ID=your_agent_id_here
WECOM_SECRET=your_secret_here
WECOM_TOKEN=your_token_here
WECOM_ENCODING_AES_KEY=your_encoding_aes_key_here
WECOM_CALLBACK_URL=https://your-domain.com/webhook/wecom

# ==========================================================
# 2. KIMI AI配置
# ==========================================================
KIMI_API_KEY=your_kimi_api_key_here

# ==========================================================
# 3. PostgreSQL数据库配置
# ==========================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=field_info_db
POSTGRES_USER=fieldcollector
POSTGRES_PASSWORD=your_secure_password_here

# ==========================================================
# 4. MinIO对象存储配置
# ==========================================================
MINIO_ENDPOINT=localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=your_secure_minio_password
MINIO_ACCESS_KEY=your_access_key
MINIO_SECRET_KEY=your_secret_key
MINIO_BUCKET=field-info

# MinIO控制台（可选）
MINIO_BROWSER_REDIRECT_URL=http://localhost:9001
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ==========================================================
# 5. Redis缓存配置
# ==========================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# ==========================================================
# 6. 数据存储路径
# ==========================================================
DATA_PATH=./data

# ==========================================================
# 7. 日志配置
# ==========================================================
LOG_LEVEL=info
LOG_FILE=./logs/field-collector.log

# ==========================================================
# 8. 应用配置
# ==========================================================
APP_NAME=FieldInfoCollector
APP_ENV=development  # development/production
APP_DEBUG=false
APP_PORT=3000

# ==========================================================
# 9. 安全配置
# ==========================================================
ENCRYPTION_KEY=your_32_byte_encryption_key_here
JWT_SECRET=your_jwt_secret_here

# ==========================================================
# 10. 监控配置（可选）
# ==========================================================
METRICS_ENABLED=true
HEALTH_CHECK_ENABLED=true
