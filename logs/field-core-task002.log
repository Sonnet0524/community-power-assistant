### рҹ“қ дҪҝз”ЁзӨәдҫӢ

```python
import asyncio
from src.tools import PostgreSQLTool, MinIOTool, RedisTool
from src.tools.types import PostgreSQLConfig, MinIOConfig, RedisConfig

async def main():
    # й…ҚзҪ®
    pg_config = PostgreSQLConfig(host="localhost", port=5432, ...)
    minio_config = MinIOConfig(endpoint="localhost:9000", ...)
    redis_config = RedisConfig(host="localhost", port=6379, ...)
    
    # дҪҝз”ЁдёҠдёӢж–Үз®ЎзҗҶеҷЁ
    async with PostgreSQLTool(pg_config) as pg, \
               MinIOTool(minio_config) as minio, \
               RedisTool(redis_config) as redis:
        
        # ж•°жҚ®еә“ж“ҚдҪң
        user = await pg.get_user("user_123")
        
        # ж–Үд»¶ж“ҚдҪң
        result = await minio.upload_file("/tmp/photo.jpg", "photos/photo.jpg")
        
        # зј“еӯҳж“ҚдҪң
        await redis.set("key", "value", expire=3600)

asyncio.run(main())
```

